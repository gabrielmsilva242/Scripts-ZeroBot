        {
            "data": "local refillList = { {id=23374,min=500,max=1500},{id=238,min=100,max=200}, } function doRefill() Game.talk('hi', 1) wait(500) Game.talk('trade', 12) wait(500) for i = 1, #refillList do local refillItem = refillList[i] local itemCount = Game.getItemCount(refillItem.id) if itemCount <= refillItem.min then while itemCount < refillItem.max do local count = refillItem.max - itemCount if count > 250 then count = 250 end Npc.buy(refillItem.id, count, false, false) wait(math.max(500, Client.getServerLatency()) + 100) itemCount = Game.getItemCount(refillItem.id) end end end Client.showMessage('Done refilling!') end doRefill()",
