        {
            "data": "local refillList = { {id=23375,min=100,max=1500},{id=237,min=100,max=1500},{id=7643,min=100,max=1500}, } function doRefill() Game.talk('hi', 1) wait(500) Game.talk('trade', 12) wait(500) for i = 1, #refillList do local refillItem = refillList[i] local itemCount = Game.getItemCount(refillItem.id) if itemCount <= refillItem.min then while itemCount < refillItem.max do local count = refillItem.max - itemCount if count > 250 then count = 250 end Npc.buy(refillItem.id, count, false, false) wait(math.max(500, Client.getServerLatency()) + 100) itemCount = Game.getItemCount(refillItem.id) end end end Client.showMessage('Done refilling!') end doRefill()",
            "waypointType": 11,
            "x": 33823,
            "y": 30780,
            "z": 7
