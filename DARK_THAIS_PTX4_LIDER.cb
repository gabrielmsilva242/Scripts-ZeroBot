            "data": "local lNeed, fNeed = false, false;\npcall(function() local f=io.open(\"zb_leader_state.txt\",\"r\"); if f then local d=f:read(\"*a\"); if d then if d:sub(1,1)==\"1\" then lNeed=true end; if d:sub(3,3)==\"1\" then fNeed=true end end; f:close() end end);\n\nif lNeed or fNeed then\n    pcall(function() local f=io.open(\"zb_leader_phase.txt\",\"w\") f:write(\"REFILL\") f:close() end)\n    CaveBot.GoTo(\"VOLTAR_SAFE\")\nelse\n    CaveBot.GoTo(\"HUNT_START\")\nend",
