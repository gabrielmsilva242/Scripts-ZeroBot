        {
            "data": "local phase = \"UNKNOWN\"; pcall(function() local f=io.open(\"zb_follower_phase.txt\",\"r\"); if f then phase=f:read(\"*a\"); f:close() end end); local myNeed = false; pcall(function() local f=io.open(\"zb_follower_need.txt\",\"r\"); if f then if f:read(\"*a\")==\"1\" then myNeed=true end; f:close() end end); if phase==\"HUNTING\" then CaveBot.GoTo(\"HUNT_IDLE\") elseif phase==\"REFILL\" and myNeed then CaveBot.GoTo(\"FAZER_REFILL\") else wait(1000); CaveBot.GoTo(\"AT_SAFE\") end",
